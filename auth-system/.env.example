# Okapi Auth System Environment Variables
# Copy to .env and fill in values. Never commit the .env file.

# ── OIDC Configuration (e.g. Okta, Keycloak) ────────────────────────
OIDC_ISSUER_URI=http://localhost:8180/realms/okapi
OIDC_CLIENT_ID=okapi-client
OIDC_CLIENT_SECRET=okapi-secret

# ── Database Configuration ───────────────────────────────────────────
# In production, these should be loaded from Secrets Manager
POSTGRES_DB=okapi_auth
POSTGRES_USER=okapi_service
POSTGRES_PASSWORD=change_me_locally
POSTGRES_PORT=5432

# ── JWT Signing (REQUIRED — change for any non-local deployment) ─────
# Must be at least 32 characters for HMAC-SHA256
OKAPI_JWT_SECRET=change-me-at-least-32-characters-long
OKAPI_JWT_ISSUER=okapi
OKAPI_JWT_AUDIENCE=okapi-tile-server
OKAPI_JWT_TTL_SECONDS=600

# ── Viewer Integration (Optional) ───────────────────────────────────
# Comma-separated origins for the viewer window when NOT behind nginx proxy
# Example: http://localhost:5174,http://viewer.okapi.local
# OKAPI_VIEWER_ALLOWED_ORIGINS=

# ── Server (Optional) ───────────────────────────────────────────────
# SERVER_PORT=8080

# ── SAML Configuration (Optional — uncomment to enable) ─────────────
# SAML_IDP_METADATA_URL=https://dev-123456.okta.com/app/exk.../sso/saml/metadata
